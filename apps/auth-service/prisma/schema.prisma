generator client { provider = "prisma-client-js" }`ndatasource db { provider = "postgresql"; url = env("DATABASE_URL") }`n`nenum UserRole { ADMIN, CLIENT, ENGINEER, ARCHITECT }`nenum PlanType { FREE, PROFESSIONAL, CORPORATE }`n`nmodel User {`n  id String @id @default(uuid())`n  email String @unique`n  password String`n  name String`n  role UserRole @default(CLIENT)`n  plan PlanType @default(FREE)`n  isVerified Boolean @default(false)`n  createdAt DateTime @default(now())`n}
